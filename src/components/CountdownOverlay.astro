---

import OssfeLogo from './OssfeLogo.astro';
interface Props {
  /** ISO 8601 date/time, e.g. "2027-01-15T12:00:00Z" */
  revealDate: string;
  title?: string;
  message?: string;
}

const {
  revealDate,
  message = "The location of the 2027 edition will be revealed in…",
} = Astro.props;
---

<div id="countdown-overlay" data-reveal={revealDate}>
  <div class="blobs">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
  </div>

  <div class="countdown-inner">
    <div class="w-72 drop-shadow-lg md:w-[28rem]">
      <OssfeLogo />
    </div>
    <p>{message}</p>
    <div id="countdown-timer">--</div>

    <form
      action="https://github.us9.list-manage.com/subscribe/post?u=5678d3a3e9f2ff97af6f010df&amp;id=9594bf47d2&amp;f_id=00f7e9e3f0"
      method="post"
      target="_blank"
      class="remind-form mx-auto mt-8 flex max-w-md flex-col gap-3 px-6 sm:flex-row sm:px-0"
    >
      <input
        type="email"
        name="EMAIL"
        required
        placeholder="you@example.com"
        class="flex-1 rounded-full border border-white/15 bg-ossfe-blue/60 px-5 py-3 font-body text-ink placeholder:text-ink-faint focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      />

      {/* Honeypot: real users never fill this; bots do. Keep it off-screen. */}
      <div aria-hidden="true" style="position:absolute; left:-5000px;">
        <input type="text" name="b_5678d3a3e9f2ff97af6f010df_9594bf47d2" tabindex="-1" value="" />
      </div>

      <button
        type="submit"
        name="subscribe"
        class="rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover"
      >
        Remind me
      </button>
    </form>

    <p class="mt-6 font-body text-sm text-ink-muted">
      or{" "}
      <a
        href="https://www.linkedin.com/company/ossfe"
        target="_blank"
        rel="noopener"
        class="font-semibold text-accent underline-offset-4 transition hover:underline"
      >follow OSSFE on LinkedIn</a>{" "}
      for the announcement.
    </p>
  </div>
</div>

<style>
  #countdown-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink);
    text-align: center;
    font-family: var(--font-display);
    overflow: hidden; /* keep blobs from spilling past edges */

    /* Base gradient */
    background: linear-gradient(
      -45deg,
      var(--color-ossfe-darker),
      var(--color-ossfe-blue),
      var(--color-ossfe-dark),
      var(--color-ossfe-blue)
    );
    background-size: 400% 400%;
    animation: gradient-shift 18s ease infinite;
  }

  /* Floating blobs container */
  .blobs {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    filter: blur(80px); /* the soft aurora glow */
  }

  .blob {
    position: absolute;
    width: 45vw;
    height: 45vw;
    border-radius: 50%;
    opacity: 0.55;
    will-change: transform;
  }

  .blob-1 {
    background: var(--color-accent);
    top: -10%;
    left: -5%;
    animation: drift-1 22s ease-in-out infinite;
  }

  .blob-2 {
    background: #0ea5e9; /* bright cyan-blue accent for depth */
    bottom: -15%;
    right: -5%;
    animation: drift-2 26s ease-in-out infinite;
  }

  .blob-3 {
    background: var(--color-ossfe-blue);
    top: 30%;
    left: 40%;
    opacity: 0.7;
    animation: drift-3 30s ease-in-out infinite;
  }

  /* Keep content above the blobs */
  .countdown-inner {
    position: relative;
    z-index: 1;
  }

  @keyframes gradient-shift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(20vw, 15vh) scale(1.2); }
  }

  @keyframes drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-18vw, -12vh) scale(1.15); }
  }

  @keyframes drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-15vw, 18vh) scale(0.85); }
  }

  #countdown-overlay h1 { font-size: 3rem; margin: 0 0 0.5rem; }

  #countdown-timer {
    font-size: 2.5rem;
    font-variant-numeric: tabular-nums;
    margin-top: 1rem;
    color: var(--color-accent);
  }

  #countdown-overlay p { color: var(--color-ink-muted); }

  @media (prefers-reduced-motion: reduce) {
    #countdown-overlay,
    .blob { animation: none; }
  }

  :global(body.locked) { overflow: hidden; }
</style>

<script>
  const overlay = document.getElementById("countdown-overlay");
  const timerEl = document.getElementById("countdown-timer");
  const revealDate = new Date(overlay?.dataset.reveal ?? "");

  /*
   * Preview backdoor: lets devs and invited sponsors see the site before the
   * public reveal. Visiting any page with `?preview=fusion` unlocks the site
   * and remembers the choice in localStorage, so subsequent navigation and
   * return visits stay unlocked. Use `?preview=off` to re-lock (e.g. to test
   * the overlay). This is obfuscation, not real security: anyone who knows the
   * token can get in, which is fine for a "not yet announced" teaser.
   */
  const PREVIEW_TOKEN = "fusion";
  const STORAGE_KEY = "ossfe-preview";

  const params = new URLSearchParams(window.location.search);
  const previewParam = params.get("preview");

  if (previewParam === "off") {
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
  } else if (previewParam === PREVIEW_TOKEN) {
    try { localStorage.setItem(STORAGE_KEY, "1"); } catch {}
  }

  let previewUnlocked = false;
  try { previewUnlocked = localStorage.getItem(STORAGE_KEY) === "1"; } catch {}

  let interval: ReturnType<typeof setInterval>;

  function reveal() {
    overlay?.remove();
    document.body.classList.remove("locked");
  }

  function update() {
    const diff = revealDate.getTime() - Date.now();

    if (diff <= 0) {
      reveal();
      clearInterval(interval);
      return;
    }

    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);

    if (timerEl) timerEl.textContent = `${d}d ${h}h ${m}m ${s}s`;
  }

  if (previewUnlocked) {
    reveal();
  } else {
    document.body.classList.add("locked");
    update();
    interval = setInterval(update, 1000);
  }
</script>