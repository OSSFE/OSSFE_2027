---
// src/components/EcosystemShowcase.astro
// Logo wall of open-source fusion projects represented at OSSFE, built from
// GitHub/GitLab links submitted with past abstracts (see src/data/projects.json).
// Reused on the homepage and the sponsors page; copy and background are props so
// each page can frame it appropriately (the edge fade must match the section bg).
import data from '../data/projects.json';

interface Props {
  variant?: 'blue' | 'dark';
  eyebrow?: string;
  title?: string;
  intro?: string;
}

const {
  variant = 'blue',
  eyebrow = 'One community, one stack',
  title = `${data.totalProjectCount}+ open-source projects vital to fusion`,
  intro = 'From equilibrium solvers to neutronics, from data pipelines to reactor design frameworks, OSSFE brings together the people who build the tools the field runs on. OSSFE supports the whole stack, not just one project.',
} = Astro.props;

const bgClass = variant === 'dark' ? 'bg-ossfe-dark' : 'bg-ossfe-blue';
const fadeFrom = variant === 'dark' ? 'from-ossfe-dark' : 'from-ossfe-blue';

const base = import.meta.env.BASE_URL;
const logos = data.logos;
// Duplicate the row so the CSS marquee can loop seamlessly.
const track = [...logos, ...logos];
---

<section id="ecosystem" class:list={[bgClass, 'py-24']}>
  <div class="mx-auto max-w-5xl px-6 text-center">
    <p class="font-body text-sm uppercase tracking-widest text-accent">{eyebrow}</p>
    <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-2xl font-body text-ink-muted">{intro}</p>
  </div>

  <div id="logo-marquee" class="group relative mt-14 overflow-hidden">
    <div class="marquee-track flex w-max items-center gap-12 px-6">
      {track.map((p) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          title={p.name}
          class="flex h-20 w-24 shrink-0 items-center justify-center rounded-xl bg-ink/5 p-3 ring-1 ring-ink/10 transition hover:bg-ink/10"
        >
          <img
            src={`${base}${p.logo}`}
            alt={`${p.name} logo`}
            loading="lazy"
            class="max-h-12 max-w-full rounded object-contain opacity-80 grayscale transition hover:opacity-100 hover:grayscale-0"
          />
        </a>
      ))}
    </div>
    <!-- edge fade so the loop point stays hidden -->
    <div class:list={['pointer-events-none absolute inset-y-0 left-0 w-16 bg-gradient-to-r to-transparent', fadeFrom]}></div>
    <div class:list={['pointer-events-none absolute inset-y-0 right-0 w-16 bg-gradient-to-l to-transparent', fadeFrom]}></div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 60s linear infinite;
  }
  #logo-marquee:hover .marquee-track {
    animation-play-state: paused;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
  }
</style>
