---
// src/components/Footer.astro
import Icon from './Icon.astro';
const base = import.meta.env.BASE_URL;
const nav = [
  { href: `${base}#about`, label: 'About' },
  { href: `${base}#cfp`, label: 'Call for Proposals' },
  { href: `${base}#program`, label: 'Program' },
  { href: `${base}#sponsors`, label: 'Sponsors' },
  { href: `${base}#travel`, label: 'Travel' },
];
const socials = [
  { href: 'https://www.youtube.com/watch?v=pcuDrO1bBdU', label: 'YouTube', icon: 'youtube' },
  { href: 'https://www.linkedin.com/company/ossfe', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'https://github.com/OSSFE', label: 'GitHub', icon: 'github' },
];
const year = new Date().getFullYear();
---

<footer class="bg-ossfe-darker py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-10 md:grid-cols-3">

      {/* Logo + blurb */}
      <div>
        <img src=`${base}images/ossfe light transparent cropped.svg` alt="OSSFE" class="h-14 w-auto" />
        <p class="mt-4 max-w-xs font-body text-sm text-ink-faint">
          Open Source Software for Fusion Energy.
        </p>
      </div>

      {/* Nav */}
      <div>
        <h3 class="font-display text-sm uppercase tracking-widest text-accent">Explore</h3>
        <ul class="mt-4 space-y-2">
          {nav.map((l) => (
            <li><a href={l.href} class="font-body text-sm text-ink-muted transition hover:text-ink">{l.label}</a></li>
          ))}
        </ul>
      </div>

      {/* Contact + socials */}
      <div>
        <h3 class="font-display text-sm uppercase tracking-widest text-accent">Connect</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="mailto:contact@ossfe.org" class="font-body text-sm text-ink-muted transition hover:text-ink">contact@ossfe.org</a></li>
          <li><a href="mailto:sponsors@ossfe.org" class="font-body text-sm text-ink-muted transition hover:text-ink">sponsors@ossfe.org</a></li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-3">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} title={s.label}
               class="flex h-10 w-10 items-center justify-center rounded-full text-ink-faint ring-1 ring-white/10 transition hover:text-accent hover:ring-accent/40">
              <Icon name={s.icon} class="h-5 w-5" />
            </a>
          ))}
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="font-body text-xs text-ink-faint">© {year} OSSFE. All rights reserved.</p>
      <div class="flex gap-6">
        <a href={`${base}code-of-conduct`} class="font-body text-xs text-ink-faint transition hover:text-ink">Code of Conduct</a>
        <a href={`${base}privacy`} class="font-body text-xs text-ink-faint transition hover:text-ink">Privacy</a>
        <button type="button" onclick="window.ossfeCookieSettings && window.ossfeCookieSettings()" class="font-body text-xs text-ink-faint transition hover:text-ink">Cookie settings</button>
      </div>
    </div>
  </div>
</footer>