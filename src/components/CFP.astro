---
// src/components/CFP.astro
// Call for Proposals section, wired to the pretalx CFP.
// Note: pretalx sends X-Frame-Options: DENY, so the CFP cannot be iframe-embedded;
// we link out to it in a new tab instead.

const cfpUrl = "https://pretalx.com/ossfe2027/cfp";

const formats = [
  { icon: "🎤", title: "Talks", body: "Share a tool, a result, or a lesson learned with the community." },
  { icon: "🛠️", title: "Tutorials", body: "Hands-on sessions that get people up and running with your software." },
  { icon: "📊", title: "Posters", body: "Present work in progress and spark hallway conversations." },
];
---

<section id="cfp" class="scroll-mt-24 bg-ossfe-blue py-24">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Heading + intro -->
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-body text-sm uppercase tracking-widest text-accent">Call for Proposals</p>
      <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">Submit a talk</h2>
      <p class="mt-6 font-body text-lg leading-relaxed text-ink-muted">
        Got a tool, a workflow, or a story the fusion software community should hear?
        We want to hear from maintainers, researchers, and newcomers alike. Proposals
        are handled through pretalx.
      </p>
    </div>

    <!-- Submission formats -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {formats.map((f) => (
        <div class="rounded-2xl bg-ossfe-dark/60 p-8 ring-1 ring-white/5 transition hover:ring-accent/40">
          <div class="text-3xl">{f.icon}</div>
          <h3 class="mt-4 font-display text-xl text-ink">{f.title}</h3>
          <p class="mt-3 font-body text-sm leading-relaxed text-ink-faint">{f.body}</p>
        </div>
      ))}
    </div>

    <!-- Primary CTA -->
    <div class="mt-14 text-center">
      <a
        href={cfpUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover"
      >
        Submit your proposal
      </a>
      <p class="mt-3 font-body text-xs text-ink-faint">Opens pretalx.com in a new tab.</p>
    </div>

  </div>
</section>
